---
import { ChevronRight } from "@lucide/astro";
import type { Role } from "../../data/experiences";
export interface Props {
    role: Role;
    date?: string;
}

const { role, date } = Astro.props;
---

<div class="mb-8 last:mb-0">
    <div class="flex flex-col md:flex-row md:justify-between md:items-baseline mb-3 gap-1">
        <h3
            class="text-lg md:text-xl font-bold text-ctp-sapphire"
        >
            {role.title}
        </h3>
        {date && (
            <span class="text-subtext1 text-sm font-medium whitespace-nowrap">
                {date}
            </span>
        )}
    </div>
    {role.bulletPoints && role.bulletPoints.length > 0 && (
        <ul class="mb-4 space-y-2">
            {role.bulletPoints.map((point) => (
                <li class="flex items-start gap-2 text-subtext1 text-sm md:text-base leading-relaxed">
                    <ChevronRight class="w-4 h-4 mt-1 flex-shrink-0 text-ctp-sapphire" aria-hidden="true" />
                    <span>{point}</span>
                </li>
            ))}
        </ul>
    )}

    <div class="flex flex-wrap gap-2" data-skills-container>
        {
            role.skills.map((skill, index) => (
                <span
                    class="skill-pill px-2.5 py-1 text-xs font-bold rounded-md
                           text-ctp-crust transition-all duration-200 ease-in-out
                           transform hover:scale-105 cursor-default shadow-sm"
                    data-skill-index={index}
                >
                    {skill}
                </span>
            ))
        }
    </div>
</div>
